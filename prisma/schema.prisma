generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  username  String   @unique
  createdAt DateTime @default(now())
  entries   Entry[]
}

model Competition {
  id            String   @id @default(cuid())
  title         String
  description   String
  imageUrl      String
  entryFee      Float
  ticketsToSell Int
  ticketsSold   Int      @default(0)
  endDate       DateTime
  createdAt     DateTime @default(now())  // ✅ Make sure this exists!
 updatedAt DateTime @updatedAt // ✅ this will auto-fill the value


  entries       Entry[]
}



model Entry {
  id        String   @id @default(cuid())
  quantity  Int
  createdAt DateTime @default(now())

  userId        String
  competitionId String

  user        User        @relation(fields: [userId], references: [id])
  competition Competition @relation(fields: [competitionId], references: [id])
}
