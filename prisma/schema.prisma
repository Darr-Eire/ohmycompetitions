generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  username  String   @unique
  entries   Entry[]  @relation("UserEntries") // ✅ define relation name
  createdAt DateTime @default(now())
}

model Competition {
  id            String    @id @default(cuid())
  title         String
  description   String?
  image         String?
  prize         String?
  slug          String    @unique
  totalTickets  Int       @default(1000)
  ticketsSold   Int       @default(0)
  entryFee      String
  endDate       DateTime?
  createdAt     DateTime  @default(now())  // ✅ Add this line
  updatedAt     DateTime  @default(now()) @updatedAt
  entries       Entry[]   @relation("CompetitionEntries")
}






model Entry {
  id            String   @id @default(cuid())
  userId        String
  competitionId String
  paymentId     String   @unique
  txid          String?
  status        String   @default("pending")
  createdAt     DateTime @default(now())

  user        User        @relation("UserEntries", fields: [userId], references: [id])
  competition Competition @relation("CompetitionEntries", fields: [competitionId], references: [id])
}

